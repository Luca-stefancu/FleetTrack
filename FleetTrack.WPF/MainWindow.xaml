<Window x:Class="FleetTrack.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vehicul" Height="350" Width="400">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="LightBlue"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </Window.Resources>
    <Grid>
        <StackPanel Margin="20">

            <TextBlock Text="Informatii Vehicul" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Numar:"/>
            <TextBox x:Name="txtNumar"/>

            <TextBlock Text="Marca:"/>
            <TextBox x:Name="txtMarca"/>

            <TextBlock Text="Model:"/>
            <TextBox x:Name="txtModel"/>

            <TextBlock Text="Capacitate:"/>
            <TextBox x:Name="txtCapacitate"/>

            <Button Content="Afiseaza" Click="Button_Click" Margin="0,20,0,0"/>

            <TextBlock x:Name="txtRezultat" Margin="0,20,0,0" FontWeight="Bold"/>

        </StackPanel>
    </Grid>
</Window>
 